## Example environment variables for CareerPilot AI backend
# Copy this file to `.env` and fill in real values. NEVER commit real secrets.

# MongoDB connection URI (use a user with limited privileges)
MONGO_URI=mongodb+srv://<db_user>:<db_password>@cluster0.mongodb.net/<database_name>

# IBM / external API keys — keep these secret and rotate if exposed
IBM_API_KEY=your_ibm_api_key
IBM_PROJECT_ID=your_project_id
IBM_URL=https://us-south.ml.cloud.ibm.com

# JWT secret used for server-signed tokens (use a long random value)
JWT_SECRET=replace_with_a_strong_random_secret

# Backend allowed origins (comma-separated) — for configuring CORS
ALLOWED_ORIGINS=http://localhost:5173
